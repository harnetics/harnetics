# ================================================================
# Harnetics 环境变量配置
# 复制此文件为 .env 并填入实际值
# ================================================================

# ---- LLM 配置 ----
# 模型名称（直接写 OpenAI-compatible 请求体里的原始 model）
# 本地: gemma4:26b
# 云端: claude-sonnet-4-6, claude-sonnet-4-6-think, gpt-4o-mini
HARNETICS_LLM_MODEL=gemma4:26b

# LLM API 基础地址 (本地 Ollama 默认 http://localhost:11434)
HARNETICS_LLM_BASE_URL=http://localhost:11434

# 云端 LLM API Key (本地模型留空)
HARNETICS_LLM_API_KEY=

# ---- Embedding 向量模型配置 ----
# 本地: paraphrase-multilingual-MiniLM-L12-v2 (sentence-transformers)
# 云端: jina-embeddings-v5-text-small, text-embedding-3-small, text-embedding-3-large
# 云端 embedding 直接写请求体里的原始 model；诊断层会额外显示 normalized effective route
HARNETICS_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# 云端 Embedding API Key (本地模型留空)
HARNETICS_EMBEDDING_API_KEY=

# 云端 Embedding API 基础地址 (仅云端模型需要)
HARNETICS_EMBEDDING_BASE_URL=

# ---- 存储路径 ----
# HARNETICS_DATABASE_PATH=var/harnetics.db
# HARNETICS_GRAPH_DB_PATH=var/harnetics-graph.db
# HARNETICS_CHROMA_DIR=var/chroma
# HARNETICS_RAW_UPLOAD_DIR=var/uploads
# HARNETICS_EXPORT_DIR=var/exports

# ---- 服务器 ----
# HARNETICS_SERVER_PORT=8000
