# ================================================================
# Harnetics 环境变量配置
# 复制此文件为 .env 并填入实际值
# ================================================================

# ---- LLM 配置 ----
# 模型名称（直接写 OpenAI-compatible 请求体里的原始 model）
# 云端: gpt-4o-mini, claude-sonnet-4-6, claude-sonnet-4-6-think
# 本地 Ollama: qwen3.5:4b, gemma4:26b
HARNETICS_LLM_MODEL=gpt-4o-mini

# LLM API 基础地址 (留空走 SDK 默认；本地 Ollama 使用 http://localhost:11434)
HARNETICS_LLM_BASE_URL=

# 云端 LLM API Key (本地 Ollama 留空)
HARNETICS_LLM_API_KEY=

# SiliconFlow thinking 参数：模型支持时才会把 enable_thinking 写入请求 body
HARNETICS_LLM_THINKING_SUPPORTED=false
HARNETICS_LLM_ENABLE_THINKING=false

# ---- Embedding 向量模型配置 ----
# 云端: jina-embeddings-v5-text-small, text-embedding-3-small, text-embedding-3-large
# 本地 Ollama: nomic-embed-text
# 直接写请求体里的原始 model；诊断层会额外显示 normalized effective route
HARNETICS_EMBEDDING_MODEL=text-embedding-3-small

# 云端 Embedding API Key (本地 Ollama 留空)
HARNETICS_EMBEDDING_API_KEY=

# Embedding API 基础地址 (留空走 SDK 默认；本地 Ollama 使用 http://localhost:11434)
HARNETICS_EMBEDDING_BASE_URL=

# LLM 通用生成上限与请求超时
HARNETICS_LLM_MAX_TOKENS=16384
HARNETICS_LLM_TIMEOUT_SECONDS=180

# ---- 文档比对四步流程 ----
# Step1: 审查大纲需求扫描 JSON 输出预算
HARNETICS_COMPARISON_STEP1_MAX_TOKENS=8192

# Step3: 每批评估需求条数，越小越稳，越大越省请求
HARNETICS_COMPARISON_4STEP_BATCH_SIZE=10

# Step3: 每批覆盖度评估 JSON 输出预算
HARNETICS_COMPARISON_STEP3_MAX_TOKENS=16384

# Step4: 全局校验 JSON 输出预算
HARNETICS_COMPARISON_STEP4_MAX_TOKENS=4096

# ---- 存储路径 ----
# HARNETICS_DATABASE_PATH=var/harnetics.db
# HARNETICS_GRAPH_DB_PATH=var/harnetics-graph.db
# HARNETICS_CHROMA_DIR=var/chroma
# HARNETICS_RAW_UPLOAD_DIR=var/uploads
# HARNETICS_EXPORT_DIR=var/exports

# ---- 服务器 ----
# HARNETICS_SERVER_PORT=8000
