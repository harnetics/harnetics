{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harnetics",
  "version": "0.1.1",
  "identifier": "com.harnetics.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:8000",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Harnetics",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 720,
        "url": "http://127.0.0.1:8000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "category": "Productivity",
    "shortDescription": "Commercial aerospace document alignment workbench",
    "longDescription": "Harnetics packages a local document alignment API and React workbench as a desktop application.",
    "externalBin": ["binaries/harnetics-server"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "perMachine",
        "languages": ["SimpChinese", "English"]
      }
    }
  }
}
